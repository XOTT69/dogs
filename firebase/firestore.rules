rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if user is member of workspace
    function isMember(workspaceId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    // Check if user is owner of workspace
    function isOwner(workspaceId) {
      return isAuth() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    // Validate string field
    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    // Validate event data
    function isValidEvent() {
      let data = request.resource.data;
      return data.eventType is string &&
             data.eventType.size() > 0 &&
             data.eventType.size() <= 30 &&
             data.byUid == request.auth.uid &&
             data.byName is string &&
             data.byName.size() <= 100 &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500)) &&
             (!('value' in data) || (data.value is number && data.value >= 0 && data.value <= 999)) &&
             (!('timeLabel' in data) || (data.timeLabel is string && data.timeLabel.size() <= 10));
    }

    // Validate pet data
    function isValidPet() {
      let data = request.resource.data;
      return (!('name' in data) || isValidString(data.name, 50)) &&
             (!('breed' in data) || isValidString(data.breed, 100)) &&
             (!('sex' in data) || data.sex in ['хлопчик', 'дівчинка']) &&
             (!('toiletMode' in data) || data.toiletMode in ['pad', 'outdoor', 'transition']) &&
             (!('petType' in data) || data.petType in ['dog', 'cat']) &&
             (!('issues' in data) || isValidString(data.issues, 500)) &&
             (!('weight' in data) || data.weight is string || data.weight is number) &&
             (!('photoURL' in data) || isValidString(data.photoURL, 500));
    }

    // ===== USER PROFILES =====
    match /users/{uid} {
      // Any authenticated user can read (for invite system)
      allow read: if isAuth();
      // Only own profile
      allow create, update: if isAuth() && request.auth.uid == uid &&
        request.resource.data.uid == uid &&
        isValidString(request.resource.data.get('email', ''), 320) &&
        isValidString(request.resource.data.get('displayName', ''), 100);
      allow delete: if false;
    }

    // ===== WORKSPACES =====
    match /workspaces/{workspaceId} {
      // Only members can read
      allow read: if isMember(workspaceId);

      // Only authenticated user can create (must be owner)
      allow create: if isAuth() &&
        request.resource.data.ownerId == request.auth.uid &&
        isValidString(request.resource.data.get('name', ''), 50) &&
        request.resource.data.inviteCode is string &&
        request.resource.data.inviteCode.size() >= 4 &&
        request.resource.data.inviteCode.size() <= 12;

      // Only owner can update (can change currentPetId but not ownerId)
      allow update: if isOwner(workspaceId) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        (!('currentPetId' in request.resource.data) || isValidString(request.resource.data.currentPetId, 50));

      // Only owner can delete
      allow delete: if isOwner(workspaceId);

      // ===== MEMBERS =====
      match /members/{memberUid} {
        // Members can read all members
        allow read: if isMember(workspaceId);

        // Can create own membership (join via API sets this)
        allow create: if isAuth() && memberUid == request.auth.uid &&
          request.resource.data.uid == request.auth.uid &&
          isValidString(request.resource.data.get('displayName', ''), 100) &&
          request.resource.data.get('role', 'member') in ['member', 'owner'];

        // Can update own data (e.g., push token)
        allow update: if isAuth() && memberUid == request.auth.uid &&
          request.resource.data.uid == resource.data.uid && // Can't change uid
          request.resource.data.get('role', 'member') == resource.data.get('role', 'member'); // Can't self-promote

        // Can remove self or owner can remove anyone
        allow delete: if isAuth() &&
          (memberUid == request.auth.uid || isOwner(workspaceId));
      }

      // ===== DOGS (multi-pet: dogs/{petId}) =====
      match /dogs/{dogId} {
        allow read: if isMember(workspaceId);

        // Members can create pets (any UUID, not 'primary')
        allow create: if isMember(workspaceId) &&
          dogId != 'primary' &&
          isValidPet();

        allow update: if isMember(workspaceId) && isValidPet();

        // Only owner can delete a pet
        allow delete: if isOwner(workspaceId);
      }

      // ===== EVENTS =====
      match /events/{eventId} {
        // Members can read all events
        allow read: if isMember(workspaceId);

        // Members can create events (must be own uid)
        allow create: if isMember(workspaceId) && isValidEvent();

        // Can update own events or owner can update any
        allow update: if isMember(workspaceId) &&
          (resource.data.byUid == request.auth.uid || isOwner(workspaceId));

        // Can delete own events or owner can delete any
        allow delete: if isMember(workspaceId) &&
          (resource.data.byUid == request.auth.uid || isOwner(workspaceId));
      }

      // ===== ROUTINES (future) =====
      match /routines/{routineId} {
        allow read: if isMember(workspaceId);
        allow create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId) &&
          (resource.data.get('createdBy', '') == request.auth.uid || isOwner(workspaceId));
      }

      // ===== REMINDERS (future) =====
      match /reminders/{reminderId} {
        allow read: if isMember(workspaceId);
        allow create, update: if isMember(workspaceId);
        allow delete: if isMember(workspaceId);
      }
    }

    // ===== DENY ALL OTHER =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
